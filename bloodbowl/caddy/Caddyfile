# =====================================================
#  Caddyfile · Blood Bowl Manager
# =====================================================
# SITE_ADDRESS :
#   :80            -> HTTP local simple (recommandé pour test local)
#   localhost      -> HTTPS local auto-signé
#   mondomaine.fr  -> HTTPS auto via Let's Encrypt (production)

{$SITE_ADDRESS::80} {
    encode zstd gzip

    log {
        output stdout
        format console
    }

    # Proxy vers l'API
    handle /api/* {
        reverse_proxy backend:3001 {
            transport http {
                read_timeout 30s
            }
        }
    }

    # Frontend statique (SPA)
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
