# =====================================================
#  Caddyfile · Blood Bowl Manager
# =====================================================
# Variables d'environnement supportées :
#   SITE_ADDRESS  -> nom de domaine ou :80 pour test local
#                    ex: bloodbowl.exemple.fr  (HTTPS auto via Let's Encrypt)
#                    ex: :80                   (HTTP local sur port 80)
#                    ex: localhost             (HTTPS local self-signed)

{$SITE_ADDRESS:localhost} {
    # En-têtes de sécurité
    header {
        # HSTS (un an)
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Anti-clickjacking
        X-Frame-Options "DENY"
        # Pas de sniffing MIME
        X-Content-Type-Options "nosniff"
        # Politique de référent
        Referrer-Policy "strict-origin-when-cross-origin"
        # Permissions limitées
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Supprime le X-Powered-By
        -Server
    }

    # Compression
    encode zstd gzip

    # Logs
    log {
        output stdout
        format console
    }

    # Proxy vers l'API
    handle /api/* {
        reverse_proxy backend:3001 {
            # Limite la taille pour éviter les abus
            transport http {
                read_timeout 30s
            }
        }
    }

    # Frontend statique
    handle {
        root * /srv
        try_files {path} /index.html
        file_server
    }
}
